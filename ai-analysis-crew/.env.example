# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Hostinger / custom SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=email@sparefinder.org
SMTP_PASSWORD=96Ugo14121+

# Optional aliases / compatibility
SMTP_PASS=96Ugo14121+

# From (visible sender)
SMTP_FROM=noreply@sparefinder.org
SMTP_FROM_NAME=SpareFinder

# Clerk (required for auth: profile lookup/creation when JWT has no email claim)
# Get from: https://dashboard.clerk.com → your app → API Keys → Secret key (starts with sk_...)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
# Optional: default is https://api.clerk.com/v1 (use for self-hosted Clerk)
# CLERK_API_URL=https://api.clerk.com/v1

# Supabase Database Configuration (Optional - for storing analysis results)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Server Configuration
PORT=8000

# Redis (Redis Labs or any Redis) - for caching + Pub/Sub real-time job updates
# Option A: single URL (must start with redis:// or rediss://)
# REDIS_URL=redis://default:YOUR_PASSWORD@redis-15772.c84.us-east-1-2.ec2.cloud.redislabs.com:15772
# Option B: host/port/username/password (Redis Labs style)
REDIS_HOST=redis-15772.c84.us-east-1-2.ec2.cloud.redislabs.com
REDIS_PORT=15772
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here
# When set: dashboard stats are cached; job status updates are published to Redis and broadcast to /ws/progress WebSocket clients.

# Disable CrewAI telemetry
OTEL_SDK_DISABLED=true

# Python Version
PYTHON_VERSION=3.12.0

# Marketing outbound — optional env overrides for in-process timers (one API replica only; see docs/MARKETING_CRON.md).
# Prefer Admin → Email campaigns → Find on Google to set intervals; only set these to force a value over the DB.
# MARKETING_SCHEDULED_DISCOVER_INTERVAL_SEC=86400
# MARKETING_SCHEDULED_DISCOVER_MAX_QUERIES=3
# MARKETING_SCHEDULED_DISCOVER_INITIAL_DELAY_SEC=120
# MARKETING_SCHEDULED_SEND_INTERVAL_SEC=3600
# MARKETING_SCHEDULED_SEND_BATCH=20
# MARKETING_SCHEDULED_IDLE_POLL_SEC=60
# SERPAPI_KEY=your_serpapi_key
# MARKETING_GOOGLE_SEARCH_PROVIDER=serper
# Public URL of this API (unsubscribe + email open/click tracking); defaults to FRONTEND_URL if unset
# API_PUBLIC_URL=https://your-ai-api.onrender.com
# MARKETING_TRACKING_ENABLED=1
